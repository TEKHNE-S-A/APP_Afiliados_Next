# ID del cliente/tenant para seleccionar el frontend correcto
# Valores: base | osep
CLIENT_ID=base

# Modo mock (true = sin backend real, false = usa backend)
USE_MOCK=false

# Backend API
# - Android Emulator (Genymotion): http://10.0.3.2:3000
# - Android Emulator (AVD):        http://10.0.2.2:3000
# - Dispositivo físico USB:        http://localhost:3000 (con adb reverse)
# - Dispositivo WiFi:              http://<TU_PC_IP>:3000
API_BASE_URL_ANDROID=http://10.0.2.2:3000
API_BASE_URL_IOS=http://192.168.100.56:3000

# Token temporal credencial (minutos)
TIMEOUT_TOKEN_CREDENCIAL=10

# Fallback temporal de Cartilla cuando no hay GPS (solo testing emulador)
USE_CARTILLA_NO_GPS_FALLBACK=false

# Mock de ubicación para testing (true/false)
USE_MOCK_LOCATION=false
MOCK_LOCATION_LAT=-28.4696
MOCK_LOCATION_LNG=-65.7795
