import React, { useEffect, useState } from 'react'
import { View, Text, Button, StyleSheet, ScrollView, RefreshControl, TouchableOpacity, Modal, Share, Alert } from 'react-native'
import { useAuth } from '../contexts/AuthContext'
import { apiGet } from '../services/api'
import { useNavigation } from '@react-navigation/native'
import CredencialCard from '../components/CredencialCard'

interface DashboardData {
  saldo: number
  plan: string
  estado: string
  proximoTurno: string
  tramitesPendientes: number
  notificacionesNoLeidas: number
}

export default function HomeScreen() {
  const { user, credenciales, signOut, syncCredenciales } = useAuth()
  const navigation = useNavigation()
  const [dashboard, setDashboard] = useState<DashboardData | null>(null)
  const [loading, setLoading] = useState(false)
  const [modalVisible, setModalVisible] = useState(false)
  const [selectedCredencial, setSelectedCredencial] = useState<any>(null)

  // Obtener credencial del titular (crcrepropi === 'S')
  const credencialTitular = credenciales?.find(c => c.crcrepropi === 'S') || credenciales?.[0]
  
  // Total de miembros del grupo familiar
  const totalMiembros = credenciales?.length || 0
  const miembrosFamiliares = credenciales?.filter(c => c.crcrepropi === 'N').length || 0

  const getNombreCompleto = (): string => {
    // Primero intenta obtener de la credencial titular
    if (credencialTitular?.crcreapeno) {
      return credencialTitular.crcreapeno
    }
    // Fallback a datos del usuario
    return user?.name || user?.nombre || user?.fullName || user?.username || 'Usuario'
  }

  const fetchDashboard = async () => {
    setLoading(true)
    try {
      const response = await apiGet('/dashboard')
      setDashboard(response.data)
    } catch (error) {
      console.error('Error al cargar dashboard:', error)
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    fetchDashboard()
  }, [])

  const onLogout = async () => {
    await signOut()
  }

  const handleVerTodasCredenciales = () => {
    // @ts-ignore - navigation works
    navigation.navigate('Profile')
  const handleRefreshCredencial = async () => {
    try {
      setLoading(true)
      await syncCredenciales()
    } catch (error) {
      console.error('Error al actualizar credencial:', error)
    } finally {
      setLoading(false)
    }
  }

  const handleCredencialPress = (credencial: any) => {
    setSelectedCredencial(credencial)
    setModalVisible(true)
  }

  const handleCompartirCredencial = async () => {
    try {
      const credencial = selectedCredencial
      const mensaje = `
📇 Credencial ${credencial.crcreapeno}
DNI: ${credencial.crcredni || 'N/A'}
CUIL: ${credencial.crcrecuil || 'N/A'}
Afiliado: ${credencial.crcreid || 'N/A'}
Plan: ${credencial.nuplaid || 'N/A'}
Vigencia: ${credencial.crcrefeve ? new Date(credencial.crcrefeve).toLocaleDateString() : 'N/A'}
      `.trim()
      
      await Share.share({
        message: mensaje,
        title: 'Mi Credencial'
      })
    } catch (error) {
      console.error('Error al compartir:', error)
    }
  }

  const handleActualizarCredencial = async () => {
    setModalVisible(false)
    await handleRefreshCredencial()
    Alert.alert('✅ Actualizado', 'Credencial actualizada correctamente')
  }

  const handleVerGrupoFamiliar = () => {
    setModalVisible(false)
    // @ts-ignore
    navigation.navigate('Credenciales')
  }

  return (
    <ScrollView
      style={styles.container}
      refreshControl={<RefreshControl refreshing={loading} onRefresh={fetchDashboard} />}
    >
      <View style={styles.header}>
        <Text style={styles.title}>Bienvenido</Text>
        <Text style={styles.subtitle}>{getNombreCompleto()}</Text>
      </View>

      {/* Preview de Credencial Titular */}
      {credencialTitular ? (
        <View style={styles.credencialSection}>
          <View style={styles.credencialHeader}>
            <Text style={styles.sectionTitle}>📇 Tu Credencial</Text>
            {totalMiembros > 1 && (
              <TouchableOpacity onPress={handleVerTodasCredenciales}>
                <Text style={styles.verTodasLink}>
                  Ver todas ({totalMiembros})
                </Text>
              </TouchableOpacity>
            )}
          </View>
          
          <CredencialCard
            credencial={credencialTitular}
            isTitular={credencialTitular.crcrepropi === 'S'}
            showQR={true}
            compact={false}
            onRefresh={handleRefreshCredencial}
          />

          {totalMiembros > 1 && (
            <TouchableOpacity 
              style={styles.verGrupoButton}
              onPress={handleVerTodasCredenciales}
            >
              <Text style={styles.verGrupoIcon}>👨‍👩‍👧‍👦</Text>
              <View style={styles.verGrupoTextContainer}>
                <Text style={styles.verGrupoTitle}>Grupo Familiar</Text>
                <Text style={styles.verGrupoSubtitle}>
                  {miembrosFamiliares} {miembrosFamiliares === 1 ? 'familiar' : 'familiares'} registrado{miembrosFamiliares === 1 ? '' : 's'}
                </Text>
              </View>
              <Text style={styles.verGrupoArrow}>→</Text>
            </TouchableOpacity>
          )}
        </View>
      ) : (
        <View style={styles.noCredencialContainer}>
          <Text style={styles.noCredencialIcon}>📋</Text>
          <Text style={styles.noCredencialTitle}>Sin credencial</Text>
          <Text style={styles.noCredencialText}>
            {credenciales.length === 0 
              ? 'Desliza hacia abajo para actualizar'
              : 'No se encontró credencial del titular'}
          </Text>
        </View>
      )}

      {dashboard && (
        <>
          <View style={[styles.card, styles.planCard]}>
            <Text style={styles.cardLabel}>Plan Actual</Text>
      <View style={styles.footer}>
        <Button title="Cerrar sesión" onPress={onLogout} color="red" />
      </View>

      {/* Modal con credencial completa, QR y opciones */}
      <Modal
        animationType="slide"
        transparent={true}
        visible={modalVisible}
        onRequestClose={() => setModalVisible(false)}
      >
        <View style={styles.modalOverlay}>
          <View style={styles.modalContent}>
            <ScrollView showsVerticalScrollIndicator={false}>
              {/* Header del modal */}
              <View style={styles.modalHeader}>
                <Text style={styles.modalTitle}>Tu Credencial</Text>
                <TouchableOpacity onPress={() => setModalVisible(false)}>
                  <Text style={styles.modalClose}>✕</Text>
                </TouchableOpacity>
              </View>

              {/* Credencial con QR */}
              {selectedCredencial && (
                <CredencialCard
                  credencial={selectedCredencial}
                  isTitular={selectedCredencial.crcrepropi === 'S'}
                  showQR={true}
                  compact={false}
                />
              )}

              {/* Opciones */}
              <View style={styles.modalActions}>
                <TouchableOpacity 
                  style={styles.actionButton}
                  onPress={handleActualizarCredencial}
                >
                  <Text style={styles.actionIcon}>🔄</Text>
                  <Text style={styles.actionText}>Actualizar credencial</Text>
                </TouchableOpacity>

                <TouchableOpacity 
                  style={styles.actionButton}
                  onPress={handleCompartirCredencial}
                >
                  <Text style={styles.actionIcon}>📤</Text>
                  <Text style={styles.actionText}>Compartir credencial</Text>
                </TouchableOpacity>

                {totalMiembros > 1 && (
                  <TouchableOpacity 
                    style={[styles.actionButton, styles.actionButtonPrimary]}
                    onPress={handleVerGrupoFamiliar}
                  >
                    <Text style={styles.actionIcon}>👨‍👩‍👧‍👦</Text>
                    <View style={styles.actionTextContainer}>
                      <Text style={styles.actionTextPrimary}>Ver grupo familiar</Text>
                      <Text style={styles.actionSubtext}>
                        {totalMiembros} {totalMiembros === 1 ? 'credencial' : 'credenciales'}
                      </Text>
                    </View>
                    <Text style={styles.actionArrow}>→</Text>
                  </TouchableOpacity>
                )}
              </View>
            </ScrollView>
          </View>
        </View>
      </Modal>
    </ScrollView>
  )
}
          <View style={styles.statsGrid}>
            <View style={styles.statCard}>
              <Text style={styles.statValue}>{dashboard.tramitesPendientes}</Text>
              <Text style={styles.statLabel}>Trámites</Text>
            </View>
            <View style={styles.statCard}>
              <Text style={styles.statValue}>{dashboard.notificacionesNoLeidas}</Text>
              <Text style={styles.statLabel}>Notif.</Text>
            </View>
          </View>

          <View style={styles.card}>
            <Text style={styles.cardLabel}>Estado de Cuenta</Text>
            <Text style={[styles.saldo, { color: dashboard.saldo < 0 ? '#f44336' : '#4caf50' }]}>
              ${Math.abs(dashboard.saldo).toFixed(2)}
            </Text>
          </View>

          {dashboard.proximoTurno && (
            <View style={styles.card}>
              <Text style={styles.cardLabel}>Próximo Turno</Text>
              <Text style={styles.turno}>{dashboard.proximoTurno}</Text>
            </View>
          )}
        </>
      )}

      <View style={styles.section}>
        <Text style={styles.sectionTitle}>Acceso rápido</Text>
        <Text style={styles.hint}>• Trámites — Gestiona tus solicitudes</Text>
        <Text style={styles.hint}>• Historial — Revisa transacciones</Text>
        <Text style={styles.hint}>• Perfil — Edita tu información</Text>
      </View>

      <View style={styles.footer}>
        <Button title="Cerrar sesión" onPress={onLogout} color="red" />
      </View>
    </ScrollView>
  )
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#f5f5f5' },
  header: { backgroundColor: '#2196f3', padding: 20, paddingTop: 30 },
  title: { fontSize: 22, fontWeight: 'bold', color: '#fff', textAlign: 'center' },
  
  // Vista preliminar credencial (compacta)
  credencialPreview: {
    marginHorizontal: 16,
    marginTop: 16,
    marginBottom: 16,
    backgroundColor: '#fff',
    borderRadius: 16,
    overflow: 'hidden',
    elevation: 6,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 3 },
    shadowOpacity: 0.25,
    shadowRadius: 6,
  },
  subtitle: {
