// ─────────────────────────────────────────────────────────────────────────────
//  Prisma schema — App Afiliados Next.js
//  Apunta a la MISMA base de datos que el backend Express existente.
//  Los modelos coinciden con las tablas existentes en PostgreSQL.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS (tabla legada GeneXus) ─────────────────────────────────────────

/// Usuarios del sistema (tabla principal)
model nuusuari {
  nuusuid         String          @id @default(dbgenerated("lpad((nextval('nuusuari_seq'::regclass))::text, 40, '0'::text)")) @db.VarChar(100)
  nuusuafili      String          @db.VarChar(40)
  nuplaid         String?         @db.Char(30)
  nuusufecha      DateTime        @db.Date
  nuusunroaf      String          @db.Char(20)
  nuususexo       String?         @db.Char(1)
  nuusuapell      String          @db.Char(60)
  nuusuestit      String?         @db.Char(1)
  nuusutelef      String          @default("") @db.Char(20)
  nuusumail       String          @db.VarChar(100)
  nuusubajaf      DateTime?       @db.Timestamp(6)
  nuusunivel      Int             @default(0) @db.SmallInt
  nuusugamtok     String?
  nuusugamexp     DateTime?       @db.Timestamp(6)
  nuusuactiv      String?         @default("S") @db.Char(1)
  nuusufecde      DateTime?       @db.Timestamp(6)
  nuusumotde      String?
  nuusugamrefresh String?         @db.VarChar(500)
  nurolid         Int?
  crcredus        crcredus[]
  notifications   notifications[]
  nurolper        nurolper?       @relation(fields: [nurolid], references: [nurolid], onDelete: NoAction, onUpdate: NoAction)
  nuplan          nuplan?         @relation(fields: [nuplaid], references: [nuplaid], onDelete: NoAction, onUpdate: NoAction)
  nuusuauth       nuusuauth?
  push_tokens     push_tokens[]

  @@index([nuusumail], map: "idx_nuusuari_mail")
  @@index([nuusuafili], map: "unuusuar")
  @@index([nuplaid], map: "inuusua1")
}

model nurolper {
  nurolid       Int       @id @default(autoincrement())
  nurolnombre   String    @unique @db.VarChar(100)
  nurolpermisos String
  nurolactivo   String    @default("S") @db.Char(1)
  nurolcrea     DateTime? @default(now()) @db.Timestamp(6)
  nurolultm     DateTime? @default(now()) @db.Timestamp(6)
  nuusuari      nuusuari[]
}

/// Autenticación de usuarios (contraseñas hasheadas)
model nuusuauth {
  nuusuid   String   @id @db.VarChar(100)
  nuusupass String   @db.VarChar(256)
  nuusucrea DateTime @default(now()) @db.Timestamp(6)
  nuusuultm DateTime @default(now()) @db.Timestamp(6)
  nuusuari  nuusuari @relation(fields: [nuusuid], references: [nuusuid], onDelete: Cascade, onUpdate: NoAction)

  @@index([nuusuid], map: "inuusuauth_uid")
}

// ─── USERS (tabla moderna) ────────────────────────────────────────────────────

model users {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username      String         @unique @db.VarChar(150)
  email         String?        @db.VarChar(255)
  password_hash String?
  full_name     String?        @db.VarChar(255)
  role          String?        @default("user") @db.VarChar(50)
  version       Int            @default(1)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?      @default(now()) @db.Timestamptz(6)
  audit_logs    audit_logs[]
  tramites      tramites[]
  transactions  transactions[]

  @@index([username], map: "idx_users_username")
}

// ─── CREDENCIALES ─────────────────────────────────────────────────────────────

model crcreden {
  crcreid    String     @id @db.Char(30)
  crcrefecvi DateTime   @db.Date
  crcrelin   String
  crcrenroaf String     @db.Char(20)
  crcreapeno String     @db.Char(62)
  crcreafili String     @db.VarChar(40)
  crcrecuil  BigInt
  crcreplaid String?    @db.Char(30)
  crcrei     Bytes?
  crcrei_gxi String?    @db.VarChar(2048)
  crcredocum String     @db.Char(20)
  crcresexo  String     @db.Char(1)
  crcrefecha DateTime   @db.Date
  crcrehash  String     @db.VarChar(256)
  crcreifech DateTime   @db.Timestamp(6)
  crcreparen String?    @db.VarChar(50)
  nuplan     nuplan?    @relation(fields: [crcreplaid], references: [nuplaid], onDelete: NoAction, onUpdate: NoAction)
  crcredus   crcredus[]

  @@index([crcreafili, crcreid], map: "ucrcrede")
  @@index([crcreplaid], map: "icrcred3")
}

model crcredus {
  nuusuid    String   @db.VarChar(100)
  crcreid    String   @db.Char(30)
  crcrepropi String   @db.Char(1)
  crcreden   crcreden @relation(fields: [crcreid], references: [crcreid], onDelete: NoAction, onUpdate: NoAction)
  nuusuari   nuusuari @relation(fields: [nuusuid], references: [nuusuid], onDelete: NoAction, onUpdate: NoAction)

  @@id([nuusuid, crcreid])
  @@index([nuusuid, crcrepropi(sort: Desc), crcreid], map: "ucrcredu")
  @@index([crcreid], map: "icrcred1")
}

// ─── PLANES ───────────────────────────────────────────────────────────────────

model nuplan {
  nuplaid    String     @id @db.Char(30)
  nupladescr String     @db.Char(40)
  nuplim     Bytes
  nuplim_gxi String?    @db.VarChar(2048)
  nuplalad   String     @db.Char(1)
  nuplimfech DateTime   @db.Timestamp(6)
  cacartil   cacartil[]
  crcreden   crcreden[]
  nuusuari   nuusuari[]
}

// ─── SOLICITUDES / AUTORIZACIONES ─────────────────────────────────────────────

model ausolici {
  ausolicid  String   @id @db.Char(36)
  nuusuid    String   @db.Char(40)
  ausoldescr String   @db.Char(40)
  ausolfecal DateTime @db.Timestamp(6)
  ausolfecor DateTime @db.Date
  autippreid String?  @db.Char(30)
  ausolnroaf String   @db.Char(20)
  ausoltexto String
  ausolentid String   @db.Char(30)
  ausolfecve DateTime @db.Date
  ausolextid String   @db.Char(30)
  ausolrechd String   @db.Char(1)
  ausolestad String   @db.Char(3)
  ausolentno String   @db.Char(50)
  ausolautnu String   @db.Char(40)
  ausoltipo  String   @db.Char(1)
  ausolpsoco String   @db.Char(40)
  ausolcantp Int      @db.SmallInt
  ausolobspr String   @db.Char(40)
  ausolgravc Int      @db.SmallInt

  @@index([nuusuid, ausolfecal(sort: Desc), ausolfecor(sort: Desc), ausolicid], map: "uausoli1")
}

model sia_autorizaciones {
  ausol_id_ext           String    @id @db.VarChar(40)
  ausol_estado           String?   @db.Char(3)
  ausol_aut_d_codigo     Decimal?  @db.Decimal(5, 0)
  ausol_aut_numero       Decimal?  @db.Decimal(12, 0)
  ausol_aut_cod_gra      Decimal?  @db.Decimal(2, 0)
  ausol_aut_mar          String?   @db.Char(3)
  ausol_aud_mar          String?   @db.Char(3)
  ausol_aut_estado       String?   @db.VarChar(20)
  ausol_fec_vto          DateTime? @db.Date
  ausol_rechazo_def      String?   @db.Char(1)
  ausol_aut_nro_afiliado String?   @db.VarChar(20)
  ausol_aut_nom_afi      String?   @db.VarChar(50)
  ausol_aut_prov         Decimal?  @db.Decimal(6, 0)
  ausol_aut_raz_pro      String?   @db.VarChar(35)
  ausol_aut_suc          Decimal?  @db.Decimal(4, 0)
  ausol_entidad_id       String?   @db.VarChar(30)
  ausol_texto            String?
  recibido_en            DateTime  @default(now()) @db.Timestamp(6)
}

// ─── NOTIFICACIONES ───────────────────────────────────────────────────────────

model notifications {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nuusuid        String    @db.VarChar(100)
  tipo           String    @db.VarChar(50)
  titulo         String    @db.VarChar(255)
  mensaje        String
  leida          Boolean?  @default(false)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  fecha_leida    DateTime? @db.Timestamp(6)
  metadata       Json?     @default("{}")
  version        Int       @default(1)
  nuusuari       nuusuari  @relation(fields: [nuusuid], references: [nuusuid], onDelete: Cascade, onUpdate: NoAction)

  @@index([fecha_creacion(sort: Desc)], map: "idx_notifications_fecha")
  @@index([leida], map: "idx_notifications_leida")
  @@index([nuusuid], map: "idx_notifications_usuario")
  @@index([nuusuid, leida], map: "idx_notifications_usuario_leida")
}

model push_tokens {
  id                         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nuusuid                    String   @db.VarChar(100)
  push_token                 String   @db.VarChar(500)
  plataforma                 String   @db.VarChar(20)
  fecha_registro             DateTime @default(now()) @db.Timestamp(6)
  fecha_ultima_actualizacion DateTime @default(now()) @db.Timestamp(6)
  activo                     Boolean  @default(true)
  version                    Int      @default(1)
  nuusuari                   nuusuari @relation(fields: [nuusuid], references: [nuusuid], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nuusuid, push_token], map: "unique_user_token")
  @@index([activo], map: "idx_push_tokens_activo")
  @@index([nuusuid], map: "idx_push_tokens_nuusuid")
}

model nu_notif_prefs {
  nuusuid    String   @db.VarChar(100)
  categoria  String   @db.VarChar(50)
  push       Boolean  @default(true)
  in_app     Boolean  @default(true)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@id([nuusuid, categoria])
}

// ─── CARTILLA MÉDICA ──────────────────────────────────────────────────────────

model caentida {
  caentid      String     @id @db.Char(30)
  caentapeno   String     @db.Char(50)
  caentmail    String     @db.VarChar(100)
  caentweb     String     @db.VarChar(1000)
  caentmarca   Boolean
  caentprior   Int        @db.SmallInt
  caentmatri   String?    @db.VarChar(100)
  caentobs     String?
  carubid      String?    @db.Char(30)
  caespid      String?    @db.Char(30)
  caentactivo  Boolean?   @default(true)
  caentupdated DateTime?  @default(now()) @db.Timestamp(6)
  cacartil     cacartil[]
  caendire     caendire[]

  @@index([caentprior(sort: Desc), caentapeno, caentid], map: "ucaenti1")
  @@index([caentapeno], map: "ucaentid")
  @@index([caentactivo], map: "idx_caentida_activo")
}

model caendire {
  caentid      String     @db.Char(30)
  caendid      String     @db.Char(30)
  nulocid      String     @db.Char(30)
  caendirecc   String     @db.VarChar(1024)
  caendirpri   String     @db.Char(1)
  caendgeolo   String     @db.Char(50)
  caendhorat   String     @db.VarChar(100)
  caendpenge   String     @db.Char(1)
  caendgeost   String?    @default("N") @db.Char(1)
  caendlat     Decimal?   @db.Decimal(10, 8)
  caendlng     Decimal?   @db.Decimal(11, 8)
  caendgeoerr  String?    @db.VarChar(512)
  caendgeoup   DateTime?  @db.Timestamp(6)
  caendupdated DateTime?  @db.Timestamp(6)
  nulocali     nulocali   @relation(fields: [nulocid], references: [nulocid], onDelete: NoAction, onUpdate: NoAction)
  caentida     caentida   @relation(fields: [caentid], references: [caentid], onDelete: NoAction, onUpdate: NoAction)
  caentele     caentele[]

  @@id([caentid, caendid])
  @@index([nulocid], map: "icaendi1")
}

model caentele {
  caentid    String   @db.Char(30)
  caendid    String   @db.Char(30)
  caenteleid String   @db.Char(30)
  caentelefo String   @db.Char(20)
  caentelepr String   @db.Char(1)
  caendire   caendire @relation(fields: [caentid, caendid], references: [caentid, caendid], onDelete: NoAction, onUpdate: NoAction)

  @@id([caentid, caendid, caenteleid])
}

model carubro {
  carubid    String     @id @db.Char(30)
  carubdescr String     @db.Char(40)
  carubtipor String     @db.Char(3)
  caespeci   caespeci[]
}

model caespeci {
  caespid    String     @db.Char(30)
  carubid    String     @db.Char(30)
  caespdescr String     @db.Char(40)
  cacartil   cacartil[]
  carubro    carubro    @relation(fields: [carubid], references: [carubid], onDelete: NoAction, onUpdate: NoAction)

  @@id([caespid, carubid])
  @@index([carubid], map: "icaespe1")
}

model cacartil {
  cacarid  String   @id @db.Char(36)
  nuplaid  String   @db.Char(30)
  carubid  String   @db.Char(30)
  caespid  String   @db.Char(30)
  caentid  String   @db.Char(30)
  caentida caentida @relation(fields: [caentid], references: [caentid], onDelete: NoAction, onUpdate: NoAction)
  caespeci caespeci @relation(fields: [caespid, carubid], references: [caespid, carubid], onDelete: NoAction, onUpdate: NoAction)
  nuplan   nuplan   @relation(fields: [nuplaid], references: [nuplaid], onDelete: NoAction, onUpdate: NoAction)

  @@index([nuplaid, carubid, caespid, caentid], map: "ucacart1")
  @@index([caentid], map: "icacart1")
}

model nulocali {
  nulocid    String     @id @db.Char(30)
  nulocdescr String     @db.Char(40)
  nuproid    String     @db.Char(30)
  caendire   caendire[]
}

model nu_favoritos_prestadores {
  nufavid   Int       @id @default(autoincrement())
  nuusuid   String    @db.VarChar(100)
  caentid   String    @db.Char(30)
  tipo      String    @default("favorito") @db.VarChar(20)
  nufeccrea DateTime  @default(now()) @db.Timestamp(6)
  nufecult  DateTime? @default(now()) @db.Timestamp(6)
}

// ─── NOTICIAS ─────────────────────────────────────────────────────────────────

model app_noticias {
  id           Int       @id @default(autoincrement())
  titulo       String    @db.VarChar(200)
  contenido    String?
  imagen_url   String?   @db.VarChar(500)
  tipo         String    @default("texto") @db.VarChar(10)
  activa       Boolean   @default(true)
  orden        Int       @default(0)
  version      Int       @default(1)
  fecha_inicio DateTime? @db.Timestamp(6)
  fecha_fin    DateTime? @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
}

// ─── CREDENCIAL LAYOUT ────────────────────────────────────────────────────────

model app_credencial_layout {
  id          BigInt   @id @default(autoincrement())
  scope_type  String   @db.VarChar(10)
  plan_id     String?  @db.VarChar(30)
  config_json Json
  version     Int      @default(1)
  updated_by  String?  @db.VarChar(120)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

// ─── PARÁMETROS DEL SISTEMA ───────────────────────────────────────────────────

model nusispar {
  nusisgrupa String @db.Char(30)
  nusistippa String @db.Char(30)
  nusisvalpa String

  @@id([nusisgrupa, nusistippa])
}

// ─── AUDIT ────────────────────────────────────────────────────────────────────

model audit_logs {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entity       String?
  entity_id    String?   @db.Uuid
  action       String?   @db.VarChar(50)
  payload      Json?
  performed_by String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users?    @relation(fields: [performed_by], references: [id], onUpdate: NoAction)
}

// ─── TRÁMITES Y TRANSACCIONES ─────────────────────────────────────────────────

model tramites {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo            String         @db.VarChar(150)
  descripcion     String?
  estado          String?        @default("Pendiente") @db.VarChar(50)
  version         Int            @default(1)
  fecha           DateTime?      @default(dbgenerated("CURRENT_DATE")) @db.Date
  usuario_id      String?        @db.Uuid
  beneficiario_id String?        @db.Uuid
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?      @default(now()) @db.Timestamptz(6)
  beneficiaries   beneficiaries? @relation(fields: [beneficiario_id], references: [id], onUpdate: NoAction)
  users           users?         @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)
}

model transactions {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  amount       Decimal   @db.Decimal(12, 2)
  currency     String?   @default("ARS") @db.VarChar(10)
  description  String?
  version      Int       @default(1)
  date         DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  usuario_id   String?   @db.Uuid
  external_ref String?   @db.VarChar(255)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users?    @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)
}

model beneficiaries {
  id               String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero_afiliado  String?    @unique @db.VarChar(50)
  dni              String?    @db.VarChar(50)
  nombre           String?    @db.VarChar(150)
  apellido         String?    @db.VarChar(150)
  fecha_nacimiento DateTime?  @db.Date
  parentesco       String?    @db.VarChar(80)
  plan             String?    @db.VarChar(120)
  vigencia_desde   DateTime?  @db.Date
  version          Int        @default(1)
  foto_url         String?
  metadata         Json?      @default("{}")
  created_at       DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?  @default(now()) @db.Timestamptz(6)
  tramites         tramites[]
}

// ─── MENSAJES DE SOPORTE ──────────────────────────────────────────────────────

model mensajes_soporte {
  id             Int       @id @default(autoincrement())
  nuusuid        String    @db.VarChar(100)
  asunto         String    @db.VarChar(200)
  mensaje        String
  respuesta      String?
  estado         String    @default("ABIERTO") @db.VarChar(20)
  version        Int       @default(1)
  leido_soporte  Boolean   @default(false)
  leido_usuario  Boolean   @default(false)
  respondido_por String?   @db.VarChar(100)
  respondido_at  DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
}

// ─── INFO ÚTIL (tabla legada) ─────────────────────────────────────────────────
// PK: noinfutili (UUID string). Sin campo activo ni updated_at.
// contenido largo se almacena en noinflink; titulo en noinfdescr (max 40 chars).

model noinfuti {
  noinfutili String  @id @db.Char(36)
  noinftipo  String  @db.Char(1)
  noinfdescr String  @db.Char(40)
  noinftelef String  @db.Char(20)
  noinfldire String  @db.VarChar(1024)
  noinfgeolo String  @db.Char(50)
  noinim     Bytes
  noinim_gxi String? @db.VarChar(2048)
  noinflink  String? @db.VarChar(1000)
  noinfcate  String? @db.VarChar(50)
  noinforden Int?    @default(0)
}

// ─── HISTORIAL DE ATENCIÓN ────────────────────────────────────────────────────

/// Calificaciones de atención realizadas por afiliados
model app_calificaciones {
  id             Int      @id @default(autoincrement())
  nuusuid        String   @db.VarChar(100)
  afiliado_id    String   @db.VarChar(60)
  atencion_id    String   @db.VarChar(40)
  entidad_id     String?  @db.VarChar(40)
  entidad_nombre String?  @db.VarChar(200)
  puntuacion     Int      @db.SmallInt
  comentario     String?
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @default(now()) @db.Timestamp(6)

  @@unique([nuusuid, atencion_id], map: "uq_calificacion_atencion_user")
  @@index([afiliado_id], map: "idx_app_calif_afiliado")
  @@index([created_at(sort: Desc)], map: "idx_app_calif_created")
  @@index([entidad_id], map: "idx_app_calif_entidad")
  @@index([nuusuid], map: "idx_app_calif_nuusuid")
  @@index([puntuacion], map: "idx_app_calif_puntuacion")
}

/// Desconocimientos de atención registrados por afiliados
model app_desconocimientos {
  id               Int      @id @default(autoincrement())
  nuusuid          String   @db.VarChar(100)
  afiliado_id      String   @db.VarChar(60)
  atencion_id      String   @db.VarChar(40)
  nro_delegacion   String?  @db.VarChar(10)
  nro_autorizacion String?  @db.VarChar(30)
  prestador_nombre String?  @db.VarChar(200)
  practica_detalle String?
  motivo           String   @default("no_reconozco") @db.VarChar(50)
  descripcion      String?
  estado           String   @default("pendiente") @db.VarChar(20)
  created_at       DateTime @default(now()) @db.Timestamp(6)
  updated_at       DateTime @default(now()) @db.Timestamp(6)

  @@index([afiliado_id], map: "idx_app_descon_afiliado")
  @@index([created_at(sort: Desc)], map: "idx_app_descon_created")
  @@index([estado], map: "idx_app_descon_estado")
  @@index([nuusuid], map: "idx_app_descon_nuusuid")
}

model app_functional_events {
  id          BigInt    @id @default(autoincrement())
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  event_name  String    @db.VarChar(80)
  module      String    @db.VarChar(50)
  screen      String    @db.VarChar(80)
  method      String    @db.VarChar(10)
  path        String    @db.VarChar(255)
  status_code Int
  nuusuid     String?   @db.VarChar(100)
  actor       String?   @db.VarChar(120)
  platform    String?   @db.VarChar(40)
  app_version String?   @db.VarChar(40)
  metadata    Json?

  @@index([created_at(sort: Desc)], map: "idx_app_functional_events_created_at")
  @@index([event_name], map: "idx_app_functional_events_event_name")
  @@index([module], map: "idx_app_functional_events_module")
}

