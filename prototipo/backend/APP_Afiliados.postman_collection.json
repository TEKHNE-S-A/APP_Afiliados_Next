            "body": { "mode": "raw", "raw": "{\n  \"AUSolTipo\": \"P\",\n  \"AUSolPresTipo\": \"A\",\n  \"AUSolPresId\": \"14201010101\",\n  \"AUSolGravCodigo\": 101,\n  \"AUSolPresCant\": 1,\n  \"AUSolRefAfiliado\": \"Consulta con receta\",\n  \"AUSolObsPref\": \"\",\n  \"Foto\": []\n}" }
