    {
      "name": "🔔 Notificaciones",
      "item": [
        {
          "name": "Listar notificaciones",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Marcar notificación como leída",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/mark-read/NOTIF_ID", "host": ["{{baseUrl}}"], "path": ["notifications", "mark-read", "NOTIF_ID"] }
          }
        },
        {
