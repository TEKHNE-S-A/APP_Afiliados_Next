              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"coseguroId\": \"ID_AQUI\"\n}" }
          }
        },
        {
          "name": "Historial de atención",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/sia/historial-atencion?fechaDesde=2025-01-01&fechaHasta=2025-12-31&pagina=1",
              "host": ["{{baseUrl}}"], "path": ["sia", "historial-atencion"],
              "query": [
                { "key": "fechaDesde", "value": "2025-01-01" },
                { "key": "fechaHasta", "value": "2025-12-31" },
                { "key": "pagina",     "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Detalle de consumo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/sia/detalle-consumo",
              "host": ["{{baseUrl}}"], "path": ["sia", "detalle-consumo"]
            }
          }
        }
      ]
    },

    {
      "name": "🔒 GAM — Autenticación",
      "item": [
        {
          "name": "Registrar en GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nuevo@test.com\",\n  \"password\": \"Pass1234\",\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\"\n}" }
          }
        },
        {
          "name": "Login GAM",
          "event": [{ "listen": "test", "script": { "exec": [
            "const b = pm.response.json();",
            "const t = b.access_token || b.token;",
            "if (t) pm.collectionVariables.set('userToken', t);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"usuario@test.com\",\n  \"password\": \"Pass1234\"\n}" }
          }
        },
        {
          "name": "Info usuario GAM",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/gam/userinfo",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Cambiar contraseña GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Pass1234\",\n  \"newPassword\": \"NuevaPass5678\"\n}" }
          }
        },
        {
          "name": "Recuperación de contraseña GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/password-recovery",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"usuario@test.com\"\n}" }
          }
        },
        {
          "name": "Validar usuario GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/validate-user",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"usuario@test.com\"\n}" }
          }
        },
        {
          "name": "Logout GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Sync token GAM",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/gam/sync-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"gamToken\": \"TOKEN_GAM_AQUI\"\n}" }
          }
        }
      ]
    },

