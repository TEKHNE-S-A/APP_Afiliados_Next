{
  "info": {
    "name": "APP Afiliados — Backend API",
    "description": "Colección completa del backend Node.js / Express (puerto 3000). Variables: baseUrl, adminToken, userToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "app-afiliados-backend-2026"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3000", "type": "string" },
    { "key": "userToken",  "value": "",                      "type": "string" },
    { "key": "adminToken", "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "🔑 Auth",
      "item": [
        {
          "name": "Login usuario",
          "event": [{ "listen": "test", "script": { "exec": [
            "const b = pm.response.json();",
            "const t = b.token || b.access_token;",
            "if (t) { pm.collectionVariables.set('userToken', t); pm.test('Token guardado', () => pm.expect(t).to.be.a('string')); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"rios@gmail.com\",\n  \"password\": \"12345678\"\n}" }
          }
        },
        {
          "name": "Perfil usuario autenticado",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Verificar token",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/auth/verify-token",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"\"\n}" }
          }
        },
        {
          "name": "Cambiar contraseña",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/users/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"12345678\",\n  \"newPassword\": \"nuevaPass123\"\n}" }
          }
        },
        {
          "name": "Recuperar contraseña (solicitar código)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/recover-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rios@gmail.com\"\n}" }
          }
        },
        {
          "name": "Verificar código de recuperación",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/verify-recovery-code",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rios@gmail.com\",\n  \"code\": \"123456\"\n}" }
          }
        },
        {
          "name": "Reset contraseña",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rios@gmail.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"nuevaPass123\"\n}" }
          }
        },
        {
          "name": "Sesiones activas",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/auth/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Revocar otras sesiones",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/sessions/revoke-others",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Revocar sesión por ID",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/auth/sessions/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/sessions/SESSION_ID_AQUI", "host": ["{{baseUrl}}"], "path": ["auth", "sessions", "SESSION_ID_AQUI"] }
          }
        },
        {
          "name": "Set AfiliadoId manual",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/set-afiliado-id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"afiliadoId\": \"000000380000000000001000000380\"\n}" }
          }
        }
      ]
    },

    {
      "name": "📋 Registro",
      "item": [
        {
          "name": "Registrar nuevo usuario",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nuevo@test.com\",\n  \"password\": \"Pass1234\",\n  \"cuil\": \"20123456789\",\n  \"fechaNacimiento\": \"1990-01-15\",\n  \"sexo\": \"M\",\n  \"cantidadIntegrantes\": 1\n}" }
          }
        }
      ]
    },

    {
      "name": "🪪 Credenciales",
      "item": [
        {
          "name": "Obtener credenciales grupo familiar",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/credencial",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Credenciales (alias /credenciales)",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/credenciales",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Refrescar credenciales",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/credenciales/refresh",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Sincronizar credenciales",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/credenciales/sync",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Constancia PDF",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/credencial/constancia.pdf",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Compartir credencial",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/credencial/compartir",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"afiliadoId\": \"000000380000000000001000000380\"\n}" }
          }
        },
        {
          "name": "Ver credencial compartida (por token)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/credencial/shared/TOKEN_COMPARTIDO", "host": ["{{baseUrl}}"], "path": ["credencial", "shared", "TOKEN_COMPARTIDO"] }
          }
        },
        {
          "name": "Sync manual (localhost only)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/credencial/sync-manual",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rios@gmail.com\"\n}" }
          }
        }
      ]
    },

    {
      "name": "🔐 Token de Presencialidad",
      "item": [
        {
          "name": "Validar token por afiliadoId",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/credencial/token-valido?afiliadoId=000000380000000000001000000380&token=535",
              "host": ["{{baseUrl}}"],
              "path": ["credencial", "token-valido"],
              "query": [
                { "key": "afiliadoId", "value": "000000380000000000001000000380" },
                { "key": "token",      "value": "535" }
              ]
            }
          }
        },
        {
          "name": "Validar token por DNI ✅ (requiere auth)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/credencial/token-valido-dni?dni=28878765&token=842",
              "host": ["{{baseUrl}}"],
              "path": ["credencial", "token-valido-dni"],
              "query": [
                { "key": "dni",   "value": "28878765" },
                { "key": "token", "value": "842" }
              ]
            },
            "description": "Busca en nuusuari por DNI, cruza con crcreden.crcredocum, valida token SHA256.\nRequiere Bearer token de sesión O header X-API-Key."
          }
        },
        {
          "name": "Validar token por DNI — vía API Key (SIA externo)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "CLAVE_SIA_AQUI" }],
            "url": {
              "raw": "{{baseUrl}}/credencial/token-valido-dni?dni=28878765&token=842",
              "host": ["{{baseUrl}}"],
              "path": ["credencial", "token-valido-dni"],
              "query": [
                { "key": "dni",   "value": "28878765" },
                { "key": "token", "value": "842" }
              ]
            },
            "description": "Autenticación mediante X-API-Key configurada en nusispar (CREDENCIAL.ApiKeySistemaExterno)."
          }
        },
        {
          "name": "Validar token por DNI — sin auth (401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/credencial/token-valido-dni?dni=28878765&token=842",
              "host": ["{{baseUrl}}"],
              "path": ["credencial", "token-valido-dni"],
              "query": [
                { "key": "dni",   "value": "28878765" },
                { "key": "token", "value": "842" }
              ]
            }
          }
        },
        {
          "name": "Validar token por DNI — formato inválido (400)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/credencial/token-valido-dni?dni=ABCDEF&token=99",
              "host": ["{{baseUrl}}"],
              "path": ["credencial", "token-valido-dni"],
              "query": [
                { "key": "dni",   "value": "ABCDEF" },
                { "key": "token", "value": "99" }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "🏥 SIA — Autorizaciones",
      "item": [
        {
          "name": "Prestaciones disponibles",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/sia/prestaciones",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Enrolamientos del afiliado",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/sia/enrolamientos",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"afiliadoId\": \"000000380000000000001000000380\"\n}" }
          }
        },
        {
          "name": "Enrolamientos por afiliado (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/sia/enrolamientos-afiliado?afiliadoId=000000380000000000001000000380",
              "host": ["{{baseUrl}}"], "path": ["sia", "enrolamientos-afiliado"],
              "query": [{ "key": "afiliadoId", "value": "000000380000000000001000000380" }]
            }
          }
        },
        {
          "name": "Solicitudes del afiliado",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/sia/solicitudes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",   "value": "application/json" }
