    {
      "name": "🧪 Tests Completos",
      "item": [
        {
          "name": "Test Suite Completo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test suite completo automatizado",
                  "const baseUrl = pm.environment.get('base_url');",
                  "const token = pm.environment.get('auth_token');",
                  "",
                  "if (!token) {",
                  "    console.error('❌ No hay token. Ejecutar Login primero.');",
                  "    pm.test('Token disponible', () => {",
                  "        pm.expect.fail('Ejecutar Login primero');",
                  "    });",
                  "    return;",
                  "}",
                  "",
                  "console.log('🧪 Ejecutando suite de tests...');",
                  "",
                  "// Test 1: Listar notificaciones",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/notifications?limit=5',",
                  "    method: 'GET',",
                  "    header: {",
                  "        'Authorization': 'Bearer ' + token",
                  "    }",
                  "}, (err, res) => {",
