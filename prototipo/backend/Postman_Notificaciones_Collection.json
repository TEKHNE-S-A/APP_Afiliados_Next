                  "    console.log('📧 Email:', response.nuusumail);",
                  "    console.log('🆔 ID:', response.nuusuid);",
                  "    ",
                  "    pm.test('Usuario autenticado correctamente', () => {",
                  "        pm.expect(response.nuusuid).to.be.a('string');",
                  "        pm.expect(response.nuusumail).to.be.a('string');",
                  "    });",
                  "} else {",
                  "    pm.test('Token inválido o expirado', () => {",
                  "        pm.expect.fail('Auth failed: ' + pm.response.code);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
