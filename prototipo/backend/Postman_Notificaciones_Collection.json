                  "    ",
                  "    pm.environment.set('new_notification_id', response.notification.id);",
                  "    ",
                  "    pm.test('Notificación creada correctamente', () => {",
                  "        pm.expect(response.success).to.equal(true);",
                  "        pm.expect(response.notification).to.be.an('object');",
                  "        pm.expect(response.notification.id).to.be.a('string');",
                  "        pm.expect(response.notification.tipo).to.be.a('string');",
                  "    });",
                  "} else if (pm.response.code === 400) {",
                  "    const response = pm.response.json();",
                  "    console.error('❌ Error de validación:', response.error);",
                  "    pm.test('Error de validación esperado', () => {",
