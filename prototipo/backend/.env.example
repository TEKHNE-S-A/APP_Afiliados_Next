# Backend environment variables (ejemplo)
#
# Prisma usa DATABASE_URL. Si no lo seteás, el backend puede derivarlo desde DB_* (ver abajo).
# Formato:
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:12345678@127.0.0.1:5432/app_afiliados_genexus?schema=public

# Alternativa legacy (si no seteás DATABASE_URL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=app_afiliados_genexus

# Variables PG* (compatibilidad con scripts/pg)
PGHOST=localhost
PGPORT=5432
PGUSER=tu_usuario
PGPASSWORD=tu_password
PGDATABASE=app_afiliados

# Puerto de la API
API_PORT=3000

# Directorio absoluto para uploads cuando se ejecuta en Docker/Linux.
# Si no se define, el backend intenta usar ./uploads y luego un fallback temporal escribible.
# Ejemplo Docker: /app/uploads
UPLOADS_DIR=

# SOAP URL (si aplica)
SOAP_URL=
