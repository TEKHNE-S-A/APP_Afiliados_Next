# Auto detect text files and normalize line endings to LF
* text=auto

# Force LF for shell scripts and Python
*.sh text eol=lf
*.ps1 text eol=crlf
*.py text eol=lf

# JavaScript/TypeScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Markdow
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.jar binary
*.xpz binary
