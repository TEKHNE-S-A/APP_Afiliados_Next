# ============================================================
# Tekhne Mail Service - Variables de Entorno
# ============================================================
# Copiar este archivo como .env y configurar los valores

# URL del endpoint de la API de Tekhne
# QA: http://tkqa.tekhne.com.ar:8081/api/mail/send
# Producción: Consultar con Tekhne
MAIL_API_URL=http://tkqa.tekhne.com.ar:8081/api/mail/send

# API Key de autenticación (solicitar a portal@tekhne.com.ar)
MAIL_API_KEY=TU_API_KEY_AQUI

# Email del remitente (REQUERIDO por la API)
MAIL_FROM_ADDRESS=noreply@tu-dominio.com

# Nombre del remitente (opcional, para logs)
MAIL_FROM_NAME=Mi Sistema

# URL de tu aplicación (para links en emails, opcional)
APP_URL=http://localhost:3000
